NEXT_PUBLIC_APP_URL="https://prisma-rt04.pages.dev"
NEXT_PUBLIC_ENVIRONMENT="production"

# Database Configuration (Production SQLite / Supabase)
DATABASE_URL="file:./prisma_prod.db"

